{% extends 'base.html' %}

{% block title %}Gestion des Tarifs | Coiff'Connect{% endblock %}

{% block content %}
<div class="admin-container">
    <div class="admin-header">
        <div>
            <h2>Assignation et <span class="gold-text">Tarifs</span></h2>
            <p style="color: #333; font-weight: 600; margin-top: 0.5rem;">Associez vos services aux coiffeuses et définissez leurs tarifs.</p>
        </div>
        <div class="admin-actions">
            <a href="{{ url_for('admin_dashboard') }}" class="btn-back">← Retour au Tableau</a>
        </div>
    </div>

    <div class="manage-grid mt-4">
        <!-- FORM SECTION -->
        <div class="form-card">
            <h3>Attribuer un service</h3>
            <form action="/admin/assign-skills" method="POST">
                <div class="form-group">
                    <label>Coiffeuse</label>
                    <select name="coiffeuse_id" class="form-control" required>
                        <option value="" disabled selected>Sélectionner...</option>
                        {% for s in stylists %}
                            <option value="{{ s.id }}">{{ s.alias }}</option>
                        {% endfor %}
                    </select>
                </div>
                
                <div class="form-group">
                    <label>Service</label>
                    <select name="service_id" class="form-control" required>
                        <option value="" disabled selected>Sélectionner...</option>
                        {% for s in services %}
                            <option value="{{ s.id }}">{{ s.nom }}</option>
                        {% endfor %}
                    </select>
                </div>
                
                <div class="form-group">
                    <label>Prix pour ce service ($)</label>
                    <input type="number" step="0.01" name="prix" class="form-control" required placeholder="Ex: 120.00">
                </div>
                
                <button type="submit" class="btn-submit w-100 mt-3">Enregistrer l'assignation</button>
            </form>
        </div>
        
        <!-- DISPLAY SECTION (GROUPED BY STYLIST) -->
        <div class="roster-section">
            <h3 style="color: #111; font-weight: 800; font-size: 1.5rem; margin-bottom: 1.5rem;">Grille tarifaire par Coiffeuse</h3>
            
            <div class="scrollable-container">
                <!-- THE MAGIC LOOP: Groups the flat data by stylist alias -->
                {% for stylist_alias, stylist_assignments in assignments|groupby('alias') %}
                <div class="stylist-group">
                    <h4 class="stylist-title">✂️ {{ stylist_alias }}</h4>
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th style="width: 70%;">Service</th>
                                <th>Prix Fixé</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for a in stylist_assignments %}
                            <tr>
                                <td style="font-weight: 600; color: #333;">{{ a.nom }}</td>
                                <td><span class="price-badge">{{ a.prix }}$</span></td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {% else %}
                <div style="padding: 2rem; text-align: center; background: #fdfaf5; border: 2px dashed #ddd; border-radius: 8px;">
                    <p style="color: #666; font-weight: bold; margin: 0;">Aucune assignation pour le moment.</p>
                </div>
                {% endfor %}
            </div>
            
        </div>
    </div>
</div>

